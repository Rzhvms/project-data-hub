{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Authority": "http://localhost:5248/identity",
    "AccessTokenSettings": {
      "Issuer": "http://localhost:5248/identity",
      "Audience": "IdentityClient",
      "LifeTimeInSeconds": 3600
    },
    "RefreshTokenSettings": {
      "Length": 64,
      "LifeTimeInMinutes": 10080
    }
  },
  "AuditLogCleanup": {
    "RetentionDays": 14,
    "CheckIntervalHours": 4
  },
  "JwtKeys": {
    "DirectoryPath": "identity-keys"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=Identity;Username=postgres;Password=1"
  }
}
